server {
	server_name osm.sk www.osm.sk;

	access_log /var/log/nginx/access_osm.log;
	error_log /var/log/nginx/error_osm.log warn;

	return 301 https://www.freemap.sk$request_uri;

	listen 443 ssl; # managed by Certbot
	listen [::]:443 ssl; # managed by Certbot
	ssl_certificate /etc/letsencrypt/live/osm.sk/fullchain.pem; # managed by Certbot
	ssl_certificate_key /etc/letsencrypt/live/osm.sk/privkey.pem; # managed by Certbot
	include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
	ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot
}

server {
	listen 80;
	listen [::]:80;

	server_name osm.sk www.osm.sk;

	return 301 https://www.freemap.sk$request_uri;
}
