<?xml version="1.0" encoding="UTF-8"?>
<kml xmlns="http://www.opengis.net/kml/2.2">
  <Document>
    <name>Styled drawing</name>
    <Style id="line-red"><LineStyle><color>ff0000ff</color><width>5</width></LineStyle></Style>
    <Style id="line-blue"><LineStyle><color>ffff0000</color><width>2</width></LineStyle></Style>
    <Style id="area"><LineStyle><color>ff0080ff</color><width>3</width></LineStyle><PolyStyle><color>7f00a0ff</color></PolyStyle></Style>
    <Placemark>
      <name>Restaurant (pin, Garmin sym)</name>
      <ExtendedData><Data name="marker-color"><value>#e53935</value></Data><Data name="marker-symbol"><value>Restaurant</value></Data><Data name="markerType"><value>pin</value></Data></ExtendedData>
      <Point><coordinates>21.10,48.75</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Peak (ring, POI icon)</name>
      <ExtendedData><Data name="marker-color"><value>#1e88e5</value></Data><Data name="icon"><value>poi:peak</value></Data><Data name="markerType"><value>ring</value></Data></ExtendedData>
      <Point><coordinates>21.11,48.76</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Bike (square, FA icon)</name>
      <ExtendedData><Data name="marker-color"><value>#43a047</value></Data><Data name="icon"><value>fa:bicycle</value></Data><Data name="markerType"><value>square</value></Data></ExtendedData>
      <Point><coordinates>21.12,48.75</coordinates></Point>
    </Placemark>
    <Placemark>
      <name>Dashed red line</name>
      <styleUrl>#line-red</styleUrl>
      <ExtendedData><Data name="stroke-dasharray"><value>10 6</value></Data><Data name="stroke-linecap"><value>round</value></Data><Data name="stroke-linejoin"><value>round</value></Data></ExtendedData>
      <LineString><coordinates>21.09,48.74 21.11,48.745 21.13,48.74</coordinates></LineString>
    </Placemark>
    <Placemark>
      <name>Thin blue line</name>
      <styleUrl>#line-blue</styleUrl>
      <ExtendedData><Data name="stroke-linecap"><value>butt</value></Data><Data name="stroke-linejoin"><value>miter</value></Data></ExtendedData>
      <LineString><coordinates>21.09,48.77 21.13,48.77</coordinates></LineString>
    </Placemark>
    <Placemark>
      <name>Filled area</name>
      <styleUrl>#area</styleUrl>
      <ExtendedData><Data name="stroke-dasharray"><value>4 4</value></Data><Data name="stroke-linejoin"><value>bevel</value></Data></ExtendedData>
      <Polygon><outerBoundaryIs><LinearRing><coordinates>21.09,48.75 21.10,48.78 21.13,48.78 21.13,48.75 21.09,48.75</coordinates></LinearRing></outerBoundaryIs></Polygon>
    </Placemark>
  </Document>
</kml>
