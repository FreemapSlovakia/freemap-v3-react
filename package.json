{
  "name": "freemap-sk-react",
  "version": "3.0.0",
  "description": "Freemap web portal.",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/FreemapSlovakia/freemap-v3-react.git"
  },
  "author": {
    "name": "Freemap Slovakia",
    "email": "freemap@freemap.sk"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/FreemapSlovakia/freemap-v3-react/issues"
  },
  "homepage": "https://github.com/FreemapSlovakia/freemap-v3-react",
  "lint-staged": {
    "*.{js,ts}": ["biome check", "git add"]
  },
  "scripts": {
    "start": "pnpm build:proto && pnpm sync-language-files && rspack serve --config rspack.config.ts",
    "lint": "biome check",
    "lint:fix": "biome check --write",
    "build": "pnpm build:proto && pnpm sync-language-files && tsgo --noEmit && rspack build --config rspack.config.ts",
    "sync-language-files": "tsgo -p translation-manager/tsconfig.json && node --enable-source-maps translation-manager/sync-language-files.js",
    "postinstall": "patch-package",
    "sentry-login": "sentry-cli --url https://bugsink.freemap.sk login",
    "sentry-sourcemaps": "sentry-cli sourcemaps inject dist && sentry-cli --url https://bugsink.freemap.sk sourcemaps --org freemap  --project 1 upload dist",
    "dep": "reset; DEPLOYMENT=www pnpm build && pnpm sentry-sourcemaps && rsync -av dist/ fm3:WEB",
    "gen-sitemap": "cd sitemap-generator && tsx index.ts",
    "gen-poi-icon-bboxes": "node scripts/gen-poi-icon-bboxes.mjs",
    "build:proto": "protoc -I=src --plugin=./node_modules/.bin/protoc-gen-ts_proto --ts_proto_out=src --ts_proto_opt=esModuleInterop=true,env=browser,outputServices=none,useDate=false,importSuffix=.js features/gallery/model/pictures.proto"
  },
